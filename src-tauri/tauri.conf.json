{
  "$schema": "https://schema.tauri.app/config/2",
  "productName": "obi-one",
  "version": "0.1.0",
  "identifier": "com.obione.desktop",
  "build": {
    "frontendDist": "../ui"
  },
  "app": {
    "withGlobalTauri": true,
    "windows": [
      {
        "title": "obi-one",
        "width": 1120,
        "height": 780,
        "minWidth": 920,
        "minHeight": 640
      }
    ],
    "security": {
      "csp": null
    }
  },
  "bundle": {
    "active": true,
    "targets": "all",
    "resources": [
      "resources/maisoku_template.pdf",
      "resources/maisoku_obi_band.jpg",
      "resources/pdfium/*"
    ],
    "icon": [
      "icons/icon.png",
      "icons/icon.ico"
    ],
    "macOS": {
      "signingIdentity": "-"
    }
  }
}
